{
  "global/dimension": {
    "core": {
      "dimension": {
        "50": {
          "$value": "{core.dimension.100}/2",
          "$type": "dimension",
          "$description": "Minimal spacing. Use for tight gaps."
        },
        "100": {
          "$value": "4",
          "$type": "dimension",
          "$description": "Base spacing unit. Foundation for scale."
        },
        "150": {
          "$value": "{core.dimension.100}*1.5",
          "$type": "dimension",
          "$description": "1.5x base spacing."
        },
        "200": {
          "$value": "{core.dimension.100}*2",
          "$type": "dimension",
          "$description": "Small spacing."
        },
        "300": {
          "$value": "{core.dimension.100}*3",
          "$type": "dimension",
          "$description": "Medium spacing."
        },
        "500": {
          "$value": "{core.dimension.100}*5",
          "$type": "dimension",
          "$description": "Large spacing."
        },
        "600": {
          "$value": "{core.dimension.100}*6",
          "$type": "dimension",
          "$description": "Extra large spacing."
        },
        "1000": {
          "$value": "{core.dimension.100}*10",
          "$type": "dimension",
          "$description": "3X large spacing."
        },
        "zero": {
          "$value": "0",
          "$type": "dimension",
          "$description": "Zero spacing. Removes all space."
        }
      }
    }
  },
