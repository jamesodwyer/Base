{
  "layout": {
    "spacing": {
      "cardGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing between card elements i.e. carousels, event cards"
      },
      "interactiveGap": {
        "$type": "dimension",
        "$value": "{core.dimension.400}",
        "$description": "Gap between interactive elements."
      },
      "contentToButton": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing from the bottom of any content to a main CTA"
      },
      "formGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Gap between form field elements."
      }
    }
  },
  "badge": {
    "spacing": {
      "blockPadding": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Vertical padding for badge."
      },
      "inlinePadding": {
        "$type": "spacing",
        "$value": "{core.dimension.200}",
        "$description": "Horizontal padding for badge."
      },
      "gap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between icon and label in badge."
      },
      "minHeight": {
        "$type": "dimension",
        "$value": "{core.dimension.550}",
        "$description": "Minimum height for badge."
      }
    }
  },
  "selectionControl": {
    "spacing": {
      "gap": {
        "$type": "spacing",
        "$value": "{core.dimension.300}",
        "$description": "Gap between control and label text."
      },
      "validationGap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between control row and validation message."
      },
      "errorGap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between error icon and error text."
      }
    }
  },
  "button": {
    "spacing": {
      "large": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.300}",
          "$description": "Block padding for large buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for large buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "medium": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Block padding for medium buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for medium buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "small": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Block padding for small buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for small buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      }
    }
  }
