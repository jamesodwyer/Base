{
  "layout": {
    "spacing": {
      "cardGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing between card elements i.e. carousels, event cards"
      },
      "interactiveGap": {
        "$type": "dimension",
        "$value": "{core.dimension.400}",
        "$description": "Gap between interactive elements."
      },
      "contentToButton": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing from the bottom of any content to a main CTA"
      },
      "formGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Gap between form field elements."
      }
    }
  },
  "badge": {
    "spacing": {
      "blockPadding": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Vertical padding for badge."
      },
      "inlinePadding": {
        "$type": "spacing",
        "$value": "{core.dimension.200}",
        "$description": "Horizontal padding for badge."
      },
      "gap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between icon and label in badge."
      },
      "minHeight": {
        "$type": "dimension",
        "$value": "{core.dimension.550}",
        "$description": "Minimum height for badge."
      }
    },
    "size": {
      "icon": {
        "$type": "dimension",
        "$value": "{core.dimension.300}",
        "$description": "Icon size within badge."
      }
    },
    "borderRadius": {
      "$type": "borderRadius",
      "$value": "{core.border.radius.small}",
      "$description": "Corner radius for badge."
    }
  },
  "selectionControl": {
    "size": {
      "control": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Selection control container size."
      },
      "icon": {
        "$type": "dimension",
        "$value": "{core.dimension.400}",
        "$description": "Tick and indeterminate icon size."
      },
      "errorIcon": {
        "$type": "dimension",
        "$value": "{core.dimension.400}",
        "$description": "Validation error icon size."
      }
    },
    "spacing": {
      "gap": {
        "$type": "spacing",
        "$value": "{core.dimension.300}",
        "$description": "Gap between control and label text."
      },
      "validationGap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between control row and validation message."
      },
      "errorGap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between error icon and error text."
      }
    },
    "borderRadius": {
      "control": {
        "$type": "borderRadius",
        "$value": "{core.border.radius.xSmall}",
        "$description": "Corner radius for checkbox container."
      },
      "focusRing": {
        "$type": "borderRadius",
        "$value": "{core.border.radius.small}",
        "$description": "Corner radius for focus ring."
      }
    },
    "borderWidth": {
      "default": {
        "$type": "borderWidth",
        "$value": "{core.border.width.xSmall}",
        "$description": "Border width for unchecked default state."
      },
      "active": {
        "$type": "borderWidth",
        "$value": "{core.border.width.small}",
        "$description": "Border width for hover, focus, pressed, and error states."
      },
      "focusRing": {
        "$type": "borderWidth",
        "$value": "{core.border.width.small}",
        "$description": "Focus ring border width."
      }
    },
    "color": {
      "fill": {
        "default": {
          "$type": "color",
          "$value": "{color.elevation.base}",
          "$description": "Unchecked checkbox background fill."
        },
        "checked": {
          "$type": "color",
          "$value": "{color.brand.02}",
          "$description": "Checked checkbox background fill."
        },
        "hover": {
          "$type": "color",
          "$value": "{color.selected.primary.fill.hover}",
          "$description": "Checked checkbox fill on hover."
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.selected.primary.fill.pressed}",
          "$description": "Checked checkbox fill when pressed."
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.disabled.a}",
          "$description": "Disabled checkbox background fill."
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "{color.input.border.default}",
          "$description": "Unchecked checkbox border color."
        },
        "hover": {
          "$type": "color",
          "$value": "{color.focus.border}",
          "$description": "Checkbox border on hover."
        },
        "focused": {
          "$type": "color",
          "$value": "{color.focus.border}",
          "$description": "Checkbox border when focused."
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.primary.fill.pressed}",
          "$description": "Checkbox border when pressed."
        },
        "error": {
          "$type": "color",
          "$value": "{color.input.border.error}",
          "$description": "Checkbox border for error state."
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.disabled.c}",
          "$description": "Disabled checkbox border color."
        }
      },
      "icon": {
        "default": {
          "$type": "color",
          "$value": "{color.text.onAccent}",
          "$description": "Tick and indeterminate icon color."
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.disabled.b}",
          "$description": "Disabled tick icon color."
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.text.primary}",
          "$description": "Label text color."
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.disabled.b}",
          "$description": "Disabled label text color."
        },
        "error": {
          "$type": "color",
          "$value": "{color.text.primary}",
          "$description": "Error message text color."
        }
      },
      "focusRing": {
        "$type": "color",
        "$value": "{color.focus.border}",
        "$description": "Focus ring border color."
      },
      "errorIcon": {
        "$type": "color",
        "$value": "{color.feedback.text.error}",
        "$description": "Validation error icon fill color."
      }
    }
  },
  "button": {
    "spacing": {
      "large": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.300}",
          "$description": "Block padding for large buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for large buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "medium": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Block padding for medium buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for medium buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "small": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Block padding for small buttons."
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}",
          "$description": "Inline padding for small buttons."
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      }
    }
  }
}
