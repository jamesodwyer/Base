{
  "icon": {
    "size": {
      "small": {
        "$type": "dimension",
        "$value": "{core.dimension.300}"
      },
      "medium": {
        "$type": "dimension",
        "$value": "{core.dimension.400}"
      },
      "large": {
        "$type": "dimension",
        "$value": "{core.dimension.600}"
      },
      "xLarge": {
        "$type": "dimension",
        "$value": "{core.dimension.800}"
      }
    }
  },
  "layout": {
    "spacing": {
      "inBetweenCards": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing between card elements i.e. carousels, event cards"
      },
      "inBetweenInteractive": {
        "$type": "dimension",
        "$value": "{core.dimension.400}",
        "$description": "Spacing between 2 or more interactive elements i.e. button, chips"
      },
      "contentToButton": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing from the bottom of any content to a main CTA"
      },
      "formGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing between form elements i.e. input fields and check box groups"
      }
    }
  },
  "button": {
    "spacing": {
      "large": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.300}"
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}"
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "medium": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}"
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}"
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      },
      "small": {
        "blockPadding": {
          "$type": "spacing",
          "$value": "{core.dimension.200}"
        },
        "inlinePadding": {
          "$type": "spacing",
          "$value": "{core.dimension.400}"
        },
        "gap": {
          "$type": "spacing",
          "$value": "{core.dimension.200}",
          "$description": "Gap between icon and label"
        }
      }
    }
  }
}