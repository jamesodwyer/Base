{
  "badge": {
    "spacing": {
      "blockPadding": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Vertical padding for badge."
      },
      "inlinePadding": {
        "$type": "spacing",
        "$value": "{core.dimension.200}",
        "$description": "Horizontal padding for badge."
      },
      "gap": {
        "$type": "spacing",
        "$value": "{core.dimension.100}",
        "$description": "Gap between icon and label in badge."
      },
      "minHeight": {
        "$type": "dimension",
        "$value": "{core.dimension.550}",
        "$description": "Minimum height for badge."
      }
    },
    "size": {
      "icon": {
        "$type": "dimension",
        "$value": "{core.dimension.300}",
        "$description": "Icon size within badge."
      }
    },
    "borderRadius": {
      "$type": "borderRadius",
      "$value": "{core.border.radius.small}",
      "$description": "Corner radius for badge."
    }
  },
  "layout": {
    "spacing": {
      "cardGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing between card elements i.e. carousels, event cards"
      },
      "interactiveGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Gap between interactive elements."
      },
      "contentToButton": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Spacing from the bottom of any content to a main CTA"
      },
      "formGap": {
        "$type": "dimension",
        "$value": "{core.dimension.600}",
        "$description": "Gap between form field elements."
      }
    }
  }
