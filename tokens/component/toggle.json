{
  "toggle": {
    "color": {
      "container": {
        "fill": {
          "on": {
            "default": {
              "$type": "color",
              "$value": "{color.interactive.primary.fill.default}",
              "$description": "Toggle track fill when on."
            },
            "hover": {
              "$type": "color",
              "$value": "{color.interactive.primary.fill.default}",
              "$description": "Toggle track fill when on and hovered."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.disabled.a}",
              "$description": "Toggle track fill when on and disabled."
            }
          },
          "off": {
            "default": {
              "$type": "color",
              "$value": "{color.selected.control.fill.default}",
              "$description": "Toggle track fill when off."
            },
            "hover": {
              "$type": "color",
              "$value": "{color.selected.control.fill.default}",
              "$description": "Toggle track fill when off and hovered."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.disabled.a}",
              "$description": "Toggle track fill when off and disabled."
            }
          }
        },
        "border": {
          "on": {
            "hover": {
              "$type": "color",
              "$value": "{color.brand.02}",
              "$description": "Toggle track hover overlay when on."
            }
          },
          "off": {
            "default": {
              "$type": "color",
              "$value": "{color.border.primary}",
              "$description": "Toggle track border when off."
            },
            "hover": {
              "$type": "color",
              "$value": "{color.active.border.default}",
              "$description": "Toggle track border when off and hovered."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.disabled.b}",
              "$description": "Toggle track border when off and disabled."
            }
          },
          "focus": {
            "$type": "color",
            "$value": "{color.focus.border}",
            "$description": "Toggle focus ring."
          }
        }
      },
      "thumb": {
        "fill": {
          "on": {
            "default": {
              "$type": "color",
              "$value": "{color.selected.control.fill.default}",
              "$description": "Toggle thumb fill when on."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.selected.control.fill.default}",
              "$description": "Toggle thumb fill when on and disabled."
            }
          },
          "off": {
            "default": {
              "$type": "color",
              "$value": "{color.border.primary}",
              "$description": "Toggle thumb fill when off."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.disabled.b}",
              "$description": "Toggle thumb fill when off and disabled."
            }
          }
        }
      }
    }
  }
}
