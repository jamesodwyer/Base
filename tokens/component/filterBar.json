{
  "filterBar": {
    "color": {
      "container": {
        "fill": {
          "default": {
            "$type": "color",
            "$value": "{color.selected.control.fill.default}",
            "$description": "Filter bar fill."
          },
          "hover": {
            "$type": "color",
            "$value": "{color.interactive.primary.fill.hover}",
            "$description": "Filter bar fill on hover."
          },
          "pressed": {
            "$type": "color",
            "$value": "{color.interactive.primary.fill.pressed}",
            "$description": "Filter bar fill when pressed."
          },
          "disabled": {
            "$type": "color",
            "$value": "{color.disabled.a}",
            "$description": "Filter bar fill when disabled."
          },
          "selected": {
            "default": {
              "$type": "color",
              "$value": "{color.interactive.tertiary.fill.hover}",
              "$description": "Filter bar fill when selected."
            },
            "hover": {
              "$type": "color",
              "$value": "{color.interactive.primary.fill.default}",
              "$description": "Filter bar fill when selected and hovered."
            },
            "disabled": {
              "$type": "color",
              "$value": "{color.disabled.a}",
              "$description": "Filter bar fill when selected and disabled."
            }
          }
        },
        "border": {
          "default": {
            "$type": "color",
            "$value": "{color.border.primary}",
            "$description": "Filter bar border."
          },
          "disabled": {
            "$type": "color",
            "$value": "{color.disabled.b}",
            "$description": "Filter bar border when disabled."
          },
          "focus": {
            "$type": "color",
            "$value": "{color.focus.border}",
            "$description": "Filter bar focus ring."
          }
        }
      },
      "icon": {
        "default": {
          "$type": "color",
          "$value": "{color.icon.primary}",
          "$description": "Filter bar icon in default state."
        },
        "hover": {
          "$type": "color",
          "$value": "{color.icon.inverse}",
          "$description": "Filter bar icon on hover."
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.icon.inverse}",
          "$description": "Filter bar icon when pressed."
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.disabled.b}",
          "$description": "Filter bar icon when disabled."
        },
        "selected": {
          "default": {
            "$type": "color",
            "$value": "{color.icon.inverse}",
            "$description": "Filter bar icon when selected."
          },
          "hover": {
            "$type": "color",
            "$value": "{color.icon.inverse}",
            "$description": "Filter bar icon when selected and hovered."
          }
        }
      }
    }
  }
}